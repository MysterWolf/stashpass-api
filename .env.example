# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/stashpass

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP
OTP_TTL_SECONDS=600
OTP_LENGTH=6

# Email (magic link / OTP delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@stashpass.app
SMTP_PASS=
FROM_EMAIL=noreply@stashpass.app

# SMS (OTP delivery — e.g. Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────────────────────────────────────
# StashPass API — environment variables
#
# LOCAL DEV:   copy to .env and fill in values
# RAILWAY:     set these in the Railway dashboard → Variables tab
#              (DATABASE_URL, REDIS_URL, and PORT are auto-injected by Railway)
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is injected automatically by Railway. Set locally if you need a specific port.
PORT=3000
NODE_ENV=development          # set to "production" in Railway

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add a Postgres plugin to the project.
# Locally: create a database named "stashpass" and fill in credentials.
DATABASE_URL=postgresql://postgres:password@localhost:5432/stashpass

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway auto-injects REDIS_URL when you add a Redis plugin to the project.
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED — generate a strong secret before deploying:
#   openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m            # short-lived access token; do not increase without security review
JWT_REFRESH_TTL=30d           # controls DB-side expiry of refresh tokens

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=600           # 10 minutes
OTP_LENGTH=6

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lock this down to your mobile app domain in production.
# In Railway, set to your frontend URL once it's known.
CORS_ORIGIN=*

# ── Email — OTP delivery via Resend ──────────────────────────────────────────
# RESEND_API_KEY is required in production for email OTP delivery.
# Get your key at resend.com → API Keys.
# NOTE: FROM_EMAIL domain must be verified in your Resend account.
#       Until verified, use onboarding@resend.dev for testing.
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@stashpass.app

# ── SMS — OTP delivery via Twilio ─────────────────────────────────────────────
# Optional — fill in when Twilio account is ready.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
